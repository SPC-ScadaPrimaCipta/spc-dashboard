# =========================
# App
# =========================
PORT=3002

# Public base URL of your app
# If using domain + HTTPS:
#BETTER_AUTH_URL=http://dashboard.yourdomain.com

# If no domain yet (just IP + port):
BETTER_AUTH_URL=http://145.79.15.106/:3002

# Generate using:
# openssl rand -base64 32
BETTER_AUTH_SECRET=super-long-random-string-change-this

# =========================
# Database
# =========================
POSTGRES_USER=dashboard_user
POSTGRES_PASSWORD=very-strong-password
POSTGRES_DB=dashboard_db

# =========================
# Microsoft OAuth (optional)
# =========================
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=
